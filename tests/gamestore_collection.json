{
  "info": {
    "name": "NexusGame — GameStore API",
    "description": "Collection de tests API pour le projet final 2TES3.\nCette collection doit couvrir les scénarios critiques de l'API GameStore\net démontrer le chaînage de requêtes (id récupéré d'une réponse → utilisé dans la suivante).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "description": "URL de base de l'API GameStore"
    },
    {
      "key": "created_game_id",
      "value": "",
      "description": "ID du jeu créé — rempli automatiquement par le test de création"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Ajouter les assertions Postman :",
              "// pm.test('Status 200', () => pm.response.to.have.status(200));",
              "// pm.test('Status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Lister les jeux",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/games"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier :",
              "// - status 200",
              "// - réponse est un tableau",
              "// - tableau non vide",
              "// - chaque jeu contient les champs attendus"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Créer un jeu",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/games",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"NexusGame Test {{$timestamp}}\",\n  \"genre\": \"RPG\",\n  \"price\": 49.99,\n  \"rating\": 4.5,\n  \"stock\": 100\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier status 201 et récupérer l'id pour le chaînage :",
              "// pm.test('Créé', () => pm.response.to.have.status(201));",
              "// const id = pm.response.json().id;",
              "// pm.collectionVariables.set('created_game_id', id);",
              "// pm.test('ID présent', () => pm.expect(id).to.be.a('number'));"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Récupérer le jeu créé",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/games/{{created_game_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier que le jeu créé à l'étape 3 est bien récupérable.",
              "// Utiliser created_game_id (chaînage).",
              "// Vérifier le titre, le genre, le prix."
            ]
          }
        }
      ]
    },
    {
      "name": "5. Mettre à jour le stock",
      "request": {
        "method": "PUT",
        "url": "{{base_url}}/games/{{created_game_id}}",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stock\": 0\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier status 200 et que le stock est bien mis à jour."
            ]
          }
        }
      ]
    },
    {
      "name": "6. Supprimer le jeu créé",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/games/{{created_game_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier que la suppression a réussi."
            ]
          }
        }
      ]
    },
    {
      "name": "7. Vérifier suppression (404)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/games/{{created_game_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier que le jeu n'existe plus (404).",
              "// C'est la dernière étape du scénario de chaînage complet."
            ]
          }
        }
      ]
    },
    {
      "name": "8. [LIBRE] Scénario de votre choix",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/games"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// À vous — ajoutez ici un scénario que vous jugez critique.",
              "// Exemples : filtre par genre, recherche, stats, cas d'erreur...",
              "// Documentez votre choix dans le README."
            ]
          }
        }
      ]
    }
  ]
}