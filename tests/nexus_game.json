    {
      "name": "2. Lister les jeux",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier :",
              "// - status 200",
              "// - réponse est un tableau",
              "// - tableau non vide",
              "// - chaque jeu contient les champs attendus",
              "",
              "pm.test('Status 200', () => {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test('Response is a non empty array', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "    pm.expect(body).length.to.be.greaterThan(0);",
              "});",
              "",
              "",
              "pm.test('Check game fields', () => {",
              "    const body = pm.response.json();",
              "    [\"id\", \"title\", \"genre\", \"price\", \"rating\"].forEach(field => {",
              "        pm.expect(field in body[0]).equal(true)",
              "    })",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/games",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "games"
          ]
        }
      },
      "response": []
