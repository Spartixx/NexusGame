          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Test rating sort', () => {",
              "    const games = pm.response.json();",
              "    pm.expect(games).to.be.an('array');",
              "    pm.expect(games).length.to.be.greaterThan(1);",
              "    pm.expect(games[games.length - 1][\"rating\"]).to.be.greaterThanOrEqual(games[0][\"rating\"])",
